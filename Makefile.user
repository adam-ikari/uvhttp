# UVHTTP User Makefile
# This file provides convenient shortcuts for common tasks
# Rename this file to 'GNUmakefile' if you want to use 'make' directly
# Or use: make -f Makefile.user <target>

.PHONY: help docs docs-clean docs-preview clean-all

# Default target - show help
help:
	@echo "UVHTTP Quick Start"
	@echo ""
	@echo "Common commands:"
	@echo "  make -f Makefile.user docs          - Build documentation"
	@echo "  make -f Makefile.user docs-preview  - Preview docs at http://localhost:5173"
	@echo "  make -f Makefile.user docs-clean    - Clean generated docs"
	@echo ""
	@echo "For more targets, use: make -f GNUmakefile help"

# Build documentation
docs:
	@./scripts/build_docs.sh

# Clean documentation
docs-clean:
	@./scripts/build_docs.sh clean

# Preview documentation
docs-preview:
	@cd docs && npm run dev

# Clean all
clean-all:
	@rm -rf build build_debug build_minimal_debug build_release
	@./scripts/build_docs.sh clean